---
// src/pages/proyecto/[id].astro
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

// 1. Aquí definimos todos tus proyectos y sus rutas
export function getStaticPaths() {
  const misProyectos = [
    {
      id: 'jumper', // Esta será la URL: tusitio.com/proyecto/app-ia
      titulo: 'Jumper',
      categoria: 'Programación/Multimedia',
      descripcion: 'He aquí nuestro proyecto de final de curso de primero de carrera. Este unía los conocimientos de varias asignaturas del año: programación, arquitectura de redes, física y matemáticas. Creamos una aplicación con Python que se comunica con otra aplicación móvil y representa los datos de diversas formas. En el video, de cuya edición me encargué personalmente, hay más detalles de la aplicación.',
      //enlaceRepo: 'https://github.com/tu-usuario',
      //enlaceDemo: '#',
      galeria: [
        { tipo: 'youtube', url: 'https://www.youtube.com/embed/Ho4YbvrDhwc?si=kkWlAEtVw5Lmtizm' } 
      ]
    },
    {
      id: 'carcassone', // Esta será la URL: tusitio.com/proyecto/app-ia
      titulo: 'Recreación Web del Carcassonne',
      categoria: 'Programación Web',
      descripcion: 'Para un proyecto en grupo de segundo de carrera decidimos convertir un juego de mesa en una pagina web y optamos por el Carcassonne. Este proyecto fue un reto importante para los conocimientos que teníamos entonces. Pero tuvo un resultado satisfactorio.',
      enlaceRepo: 'https://github.com/ToniTormo/TecWeb_P-Final/tree/main',
      //enlaceDemo: '#',
      galeria: [
        { tipo: 'youtube', url: 'https://www.youtube.com/embed/UFAtFWs1pt8?si=k7sREzf0OetUSmA1' } 
      ]
    },
    {
      id: 'clicker', // Esta será la URL: tusitio.com/proyecto/app-ia
      titulo: 'ETSIT Clicker',
      categoria: 'Programación',
      descripcion: 'En segundo de carrera diseñé y programé una aplicación de móvil en Android Studio usando Java. Opté por hacer un juego del estilo Cookie Clicker pero inspirado en el proceso de titulación de mi carrera. El archivo apk está en Github por si queréis probarlo.',
      enlaceRepo: 'https://github.com/dcabmar/GTDM-Clicker',
      //enlaceDemo: '#',
      galeria: [
        { tipo: 'imagen', url: 'https://res.cloudinary.com/dzjo5zpmz/image/upload/v1774891610/Clicker1_oi39ji.jpg' },
        {tipo: 'imagen', url: 'https://res.cloudinary.com/dzjo5zpmz/image/upload/v1774891610/Clicker2_jx3xr5.jpg'} 
      ]
    },
    {
      id: 'RV', // Esta será la URL: tusitio.com/proyecto/app-ia
      titulo: 'Simulador de alimentar palomas',
      categoria: 'Programación y RV',
      descripcion: 'En una asignatura de Realidad Virtual se nos encargó montar un entorno de Unity con funcionalidades personalizadas para ser usado con unas gafas de RV. Mis compañeros y yo optamos por un parque en el que tu personaje alimenta a las palomas con pan. Nos encargamos de diseñar algunos modelos 3D y de programar el entorno. Además incorporamos una animación hecha con Motion Capture en un laboratorio de nuestra facultad.',
      enlaceRepo: 'https://github.com/dcabmar/VR_Pidgeon_Feeding/tree/main',
      //enlaceDemo: '#',
      galeria: [
        { tipo: 'imagen', url: 'https://bristolpests.co.uk/media/shutterstock_1153933432-scaled.jpg' }
      ]
    },
    {
      id: 'FR', // Esta será la URL: tusitio.com/proyecto/app-ia
      titulo: 'Reconocimiento Facial',
      categoria: 'Programación e IA',
      descripcion: 'En tercero de carrera desarrollamos varios sistemas de reconocimiento facial para la asignatura de Imagen y Video digital. Estos hacían uso de modelos de aprendizaje para poder identificar correctamente los rostros. Para entrenar el algoritmo usamos fotos de youtubers e influencers, además de algunas nuestras. Así conseguimos un sistema que reconoce caras en fotos, otro en videos y uno en tiempo real; haciendo uso de una webcam.',
      enlaceRepo: 'https://github.com/dcabmar/Facial_Recognition',
      //enlaceDemo: '#',
      galeria: [
        { tipo: 'imagen', url: 'https://res.cloudinary.com/dzjo5zpmz/image/upload/v1775046103/FR1_ilujjn.avif' },
        { tipo: 'imagen', url: 'https://res.cloudinary.com/dzjo5zpmz/image/upload/v1775046103/FR2_vivkro.avif' }
      ]
    },
    {
      id: 'Voz', // Esta será la URL: tusitio.com/proyecto/app-ia
      titulo: 'Resonance',
      categoria: 'Programación y Diseño Web',
      descripcion: 'En tercero de carrera, para la asignatura de voz y audio digital, desarrollé una pagina web que aplica efectos a una grabación de audio. Gracias a una librería de JavaScript, pude recrear los efectos de chorus, reverb y eco. Además compuse unas bases para poder improvisar encima de ellas.',
      enlaceRepo: 'https://github.com/dcabmar/Pryct_VOZ/tree/main',
      //enlaceDemo: '#',
      galeria: [
        { tipo: 'imagen', url: 'https://res.cloudinary.com/dzjo5zpmz/image/upload/v1775054975/Resonance_ht6kwv.avif' }
      ]
    },
    {
      id: '2DGame', // Esta será la URL: tusitio.com/proyecto/app-ia
      titulo: 'Escudos de Katzenpisse',
      categoria: 'Programación y Diseño',
      descripcion: 'En cuarto de carrera se nos mandó a diseñar y programar un videojuego 2D en Unity. Como nos dieron libertad creativa, mi compañero y yo decidimos hacer un Tower Defense en pixel art. Nos encargamos de diseñar todos los personajes, entornos y objetos de la interfaz. Os dejo el enlace a github con el código y el video explicativo. Si queréis jugarlo solo necesitáis la carpeta "EDK". En ella esta el ejecutable.',
      enlaceRepo: 'https://github.com/ToniTormo/Games-Juego2D/tree/main',
      //enlaceDemo: '#',
      galeria: [
        { tipo: 'imagen', url: 'https://res.cloudinary.com/dzjo5zpmz/image/upload/v1775244524/KP1_w3esze.png' },
        { tipo: 'imagen', url: 'https://res.cloudinary.com/dzjo5zpmz/image/upload/v1775244526/KP2_jrghli.png' }
      ]
    },
    {
      id: 'IoT', // Esta será la URL: tusitio.com/proyecto/app-ia
      titulo: 'IoT Emergency System',
      categoria: 'Programación',
      descripcion: 'En cuarto de carrera diseñamos de forma individual sistemas que hicieran uso del Internet of Things. En mi caso diseñé un sistema de control y prevención de emergencias. Este usa una red de sensores para reaccionar ante posibles accidentes; y unos drones con cámara que envían información visual a una central de análisis. Utilicé python para diseñar varios programas para crear y actualizar entidades junto a una maquina virtual para poder hacer la simulación del sistema.',
