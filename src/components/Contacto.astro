---
// src/components/Contacto.astro
---

<section id="contacto" class="py-24">
    <div class="max-w-6xl mx-auto px-5 grid md:grid-cols-[1fr,1.5fr] gap-16 items-start">
        
        <div class="text-white space-y-6">
            <h2 class="text-5xl font-extrabold leading-tight">¿Quieres contactarme?</h2>
            <div class="space-y-2 text-lg">
                <p>Tel: <a href="tel:+34722402529" class="font-medium hover:underline">722-402-529</a></p>
                <p>Correo: <a href="mailto:dcabmar277@gmail.com" class="font-medium hover:underline">dcabmar277@gmail.com</a></p>
            </div>
            
            <div class="flex gap-4 pt-6">
                <a href="https://www.linkedin.com/in/daniel-caba%C3%B1ero-mart%C3%ADnez-632b76292/" target="_blank" rel="noopener noreferrer" class="flex justify-center items-center w-11 h-11 rounded-full bg-gray-900 text-white text-xl hover:scale-110 transition-all hover:bg-gray-800 shadow-md">
                    <i class="fab fa-linkedin-in"></i>
                </a>
            </div>
        </div>

        <form action="https://formsubmit.co/dcabmar277@gmail.com" method="POST" class="flex flex-col gap-5 bg-white/5 p-10 rounded-2xl border border-white/10 backdrop-blur-sm shadow-xl">
            
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div class="flex flex-col gap-1.5">
                    <label for="first-name" class="text-xs font-semibold text-white">First Name</label>
                    <input type="text" id="first-name" name="first-name" required class="px-4 py-3 rounded-md border border-white/30 bg-white/10 text-white placeholder:text-white/50 focus:outline-none focus:border-white/70 transition-colors" />
                </div>
                <div class="flex flex-col gap-1.5">
                    <label for="last-name" class="text-xs font-semibold text-white">Last Name</label>
                    <input type="text" id="last-name" name="last-name" required class="px-4 py-3 rounded-md border border-white/30 bg-white/10 text-white placeholder:text-white/50 focus:outline-none focus:border-white/70 transition-colors" />
                </div>
            </div>

            <div class="flex flex-col gap-1.5">
                <label for="email" class="text-xs font-semibold text-white">Email</label>
                <input type="email" id="email" name="email" required class="px-4 py-3 rounded-md border border-white/30 bg-white/10 text-white placeholder:text-white/50 focus:outline-none focus:border-white/70 transition-colors" />
            </div>

            <div class="flex flex-col gap-1.5">
                <label for="message" class="text-xs font-semibold text-white">Message</label>
                <textarea id="message" name="message" rows="6" required class="px-4 py-3 rounded-md border border-white/30 bg-white/10 text-white placeholder:text-white/50 focus:outline-none focus:border-white/70 transition-colors resize-none"></textarea>
            </div>

            <button type="submit" class="mt-4 px-6 py-3.5 bg-[#E0E0E0] text-gray-900 text-lg font-bold rounded-lg hover:bg-white active:scale-[0.98] transition-all shadow-md">Enviar</button>
            
            <input type="hidden" name="_captcha" value="false">
        </form>

    </div>
</section>