---
// src/components/Proyectos.astro
---

<section id="proyectos" class="py-20 md:py-32">
    <div class="max-w-6xl mx-auto px-5">
        
        <h2 class="text-4xl md:text-5xl font-extrabold text-white mb-10 text-center relative inline-block left-1/2 -translate-x-1/2">
            Mis Proyectos
            <span class="absolute -bottom-3 left-0 w-full h-1 bg-cyan-500 rounded-full"></span>
        </h2>

        <!-- Botones de Filtro -->
        <div class="flex flex-wrap justify-center gap-3 mb-12">
            <button class="filter-btn active px-6 py-2 rounded-full font-medium transition-all bg-cyan-600 text-white" data-filter="all">Todos</button>
            <button class="filter-btn px-6 py-2 rounded-full font-medium transition-all bg-white/5 text-gray-300 hover:bg-white/10" data-filter="programacion">Programación</button>
            <button class="filter-btn px-6 py-2 rounded-full font-medium transition-all bg-white/5 text-gray-300 hover:bg-white/10" data-filter="multimedia">Multimedia</button>
            <button class="filter-btn px-6 py-2 rounded-full font-medium transition-all bg-white/5 text-gray-300 hover:bg-white/10" data-filter="diseño">Diseño</button>
            <button class="filter-btn px-6 py-2 rounded-full font-medium transition-all bg-white/5 text-gray-300 hover:bg-white/10" data-filter="otros">Otros</button>
        </div>

        <!-- Cuadrícula de Proyectos -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="projects-grid">
            
            <!-- Proyecto 1: Programación -->
            <a href="/proyecto/jumper" class="project-card group relative block overflow-hidden rounded-2xl w-full h-80 border border border-white/10 shadow-lg" data-category="programacion multimedia">
                <img src="https://res.cloudinary.com/dzjo5zpmz/image/upload/v1774887217/Jumper_cover.png" alt="Jumper" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
                <div class="absolute inset-0 bg-slate-950/85 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col items-center justify-center p-6 text-center">
                    <h3 class="text-2xl font-bold text-white tracking-wide">Jumper</h3>
                </div>
            </a>

            <a href="/proyecto/carcassone" class="project-card group relative block overflow-hidden rounded-2xl w-full h-80 border border border-white/10 shadow-lg" data-category="programacion">
                <img src="https://res.cloudinary.com/dzjo5zpmz/image/upload/v1774889662/Favicon_xyald9.png" alt="Carcassone" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
                <div class="absolute inset-0 bg-slate-950/85 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col items-center justify-center p-6 text-center">
                    <h3 class="text-2xl font-bold text-white tracking-wide">Recreación Web del Carcassonne</h3>
                </div>
            </a>

            <a href="/proyecto/clicker" class="project-card group relative block overflow-hidden rounded-2xl w-full h-80 border border border-white/10 shadow-lg" data-category="programacion">
                <img src="https://res.cloudinary.com/dzjo5zpmz/image/upload/v1774891610/GTDM_g617bj.png" alt="Clicker" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
                <div class="absolute inset-0 bg-slate-950/85 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col items-center justify-center p-6 text-center">
                    <h3 class="text-2xl font-bold text-white tracking-wide">ETSIT Clicker</h3>
                </div>
            </a>

            <a href="/proyecto/RV" class="project-card group relative block overflow-hidden rounded-2xl w-full h-80 border border border-white/10 shadow-lg" data-category="programacion diseño">
                <img src="https://cdn.mos.cms.futurecdn.net/pDYk7ikxnKU5h6z2FdJrF4.jpg" alt="RV" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
                <div class="absolute inset-0 bg-slate-950/85 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col items-center justify-center p-6 text-center">
                    <h3 class="text-2xl font-bold text-white tracking-wide">Simulador de alimentar palomas</h3>
                </div>
            </a>

            <a href="/proyecto/FR" class="project-card group relative block overflow-hidden rounded-2xl w-full h-80 border border border-white/10 shadow-lg" data-category="programacion">
                <img src="https://img.freepik.com/fotos-premium/concepto-autenticacion-reconocimiento-facial-sistema-seguridad-biometrica-tecnologia-reconocimiento-facial_1120246-1221.jpg" alt="Reconocimiento Facial" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
                <div class="absolute inset-0 bg-slate-950/85 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col items-center justify-center p-6 text-center">
                    <h3 class="text-2xl font-bold text-white tracking-wide">Reconocimiento Facial</h3>
                </div>
            </a>

            <a href="/proyecto/Voz" class="project-card group relative block overflow-hidden rounded-2xl w-full h-80 border border border-white/10 shadow-lg" data-category="programacion multimedia">
                <img src="https://www.pointblog.com/wp-content/uploads/2022/09/comment-faire-enregistrement-audio.jpg" alt="Resonance" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
                <div class="absolute inset-0 bg-slate-950/85 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col items-center justify-center p-6 text-center">
                    <h3 class="text-2xl font-bold text-white tracking-wide">Resonance</h3>
                </div>
            </a>

            <a href="/proyecto/2DGame" class="project-card group relative block overflow-hidden rounded-2xl w-full h-80 border border border-white/10 shadow-lg" data-category="programacion diseño">
                <img src="https://res.cloudinary.com/dzjo5zpmz/image/upload/v1775244522/Moneda_oro_voqqom.png" alt="2D Game" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
                <div class="absolute inset-0 bg-slate-950/85 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col items-center justify-center p-6 text-center">
                    <h3 class="text-2xl font-bold text-white tracking-wide">Escudos de Katzenpisse</h3>
                </div>
            </a>

            <a href="/proyecto/IoT" class="project-card group relative block overflow-hidden rounded-2xl w-full h-80 border border border-white/10 shadow-lg" data-category="programacion">
                <img src="https://news.america-digital.com/wp-content/uploads/2023/03/El-auge-de-la-adopcion-de-IoT-todo-lo-que-necesitas-saber.jpg" alt="IoT" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
                <div class="absolute inset-0 bg-slate-950/85 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col items-center justify-center p-6 text-center">
                    <h3 class="text-2xl font-bold text-white tracking-wide">IoT Emergency System</h3>
                </div>
            </a>

            <a href="/proyecto/3DGame" class="project-card group relative block overflow-hidden rounded-2xl w-full h-80 border border border-white/10 shadow-lg" data-category="programacion diseño">
                <img src="https://res.cloudinary.com/dzjo5zpmz/image/upload/v1775251943/Blorg3_fk8rox.png" alt="3DGame" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
                <div class="absolute inset-0 bg-slate-950/85 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col items-center justify-center p-6 text-center">
                    <h3 class="text-2xl font-bold text-white tracking-wide">Proyecto Blorg: Gelatina en problemas</h3>
                </div>
            </a>

            <!-- Proyecto 2: Multimedia -->
            <a href="/proyecto/spot-publicitario" class="project-card group relative block overflow-hidden rounded-2xl w-full h-80 border border border-white/10 shadow-lg" data-category="multimedia">
                <img src="https://images.unsplash.com/photo-1574717024453-354056a3df3f?q=80&w=800&auto=format&fit=crop" alt="Edición Video" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
                <div class="absolute inset-0 bg-slate-950/85 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col items-center justify-center p-6 text-center">
                    <h3 class="text-2xl font-bold text-white tracking-wide">Spot Publicitario</h3>
                </div>
            </a>

            <!-- Proyecto 3: Diseño -->
            <a href="/proyecto-3d" class="project-card group relative block overflow-hidden rounded-2xl w-full h-80 border border border-white/10 shadow-lg" data-category="diseno">
                <img src="https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?q=80&w=800&auto=format&fit=crop" alt="Render 3D" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
                <div class="absolute inset-0 bg-slate-950/85 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col items-center justify-center p-6 text-center">
                    <h3 class="text-2xl font-bold text-white tracking-wide">Render 3D Interactivo</h3>
                </div>
            </a>

        </div>

    </div>
</section>

<!-- Script para hacer funcionar los filtros -->
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const buttons = document.querySelectorAll('.filter-btn');
        const cards = document.querySelectorAll('.project-card');

        buttons.forEach(button => {
            button.addEventListener('click', () => {
                // 1. Quitar estilos activos de todos los botones
                buttons.forEach(btn => {
                    btn.classList.remove('bg-cyan-600', 'text-white');
                    btn.classList.add('bg-white/5', 'text-gray-300');
                });

                // 2. Poner estilo activo al botón clicado
                button.classList.remove('bg-white/5', 'text-gray-300');
                button.classList.add('bg-cyan-600', 'text-white');

                // 3. Filtrar las tarjetas
                const filterValue = button.getAttribute('data-filter');

                cards.forEach(card => {
                    const categoriasDelProyecto = card.getAttribute('data-category').split(' ');
                    if (filterValue === 'all' || categoriasDelProyecto.includes(filterValue)) {
                        card.style.display = 'block'; // Mostrar
                        // Pequeña animación de opacidad para que no sea tan brusco
                        card.animate([{ opacity: 0 }, { opacity: 1 }], { duration: 300, fill: 'forwards' });
                    } else {
                        card.style.display = 'none'; // Ocultar
                    }
                });
            });
        });
    });
</script>